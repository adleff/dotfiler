# ~/.bashrc — drop your personal shell config here.
# dotfiler will symlink this into place via linux/home/.bashrc
#
# This is just a starting point. Add your own aliases, functions,
# exports, and prompt customization below.

# direnv hook (recommended if you use direnv for per-project env management)
# https://direnv.net/
# command -v direnv &>/dev/null && eval "$(direnv hook bash)"

# Your aliases, exports, and functions go here:
# alias ll='ls -alF'
# export EDITOR=vim
