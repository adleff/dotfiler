[default]
region = us-east-1
output = json

# Example: personal AWS account (static credentials in ~/.aws/credentials)
[profile personal]
region = us-east-1
output = json

# Example: SSO-federated profile via IAM Identity Center
[profile work-dev]
sso_session = work
sso_account_id = YOUR_ACCOUNT_ID
sso_role_name = AdministratorAccess
region = us-east-1
output = json

[sso-session work]
sso_start_url = https://YOUR_ORG.awsapps.com/start
sso_region = us-east-1
sso_registration_scopes = sso:account:access
